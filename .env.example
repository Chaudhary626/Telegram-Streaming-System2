# ─── TG Stream Server — Environment Config ──────────────

# ─── Telegram Credentials ───────────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org
API_ID=12345678
API_HASH=your_api_hash_from_my_telegram_org

# Get BOT_TOKEN from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Your Telegram channel ID (starts with -100)
# Forward a channel message to @RawDataBot to get it
CHANNEL_ID=-100XXXXXXXXXX

# ─── Database ──────────────────────────────────────────
# Same MySQL credentials as your PHP website
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# ─── Stream Server ─────────────────────────────────────
# Shared secret — MUST match STREAM_SERVER_SECRET in PHP config.php
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
STREAM_SECRET=change_me_to_a_random_64_char_hex_string

# Public URL of this server (REQUIRED for link generation)
# Examples:
#   Railway:  https://your-app.railway.app
#   Render:   https://your-app.onrender.com
#   VPS:      https://stream.yourdomain.com
STREAM_BASE_URL=https://your-app.onrender.com

# Server binding
STREAM_HOST=0.0.0.0
STREAM_PORT=8080

# ─── Admin Panel ───────────────────────────────────────
# Password for /admin login
ADMIN_PASSWORD=your_secure_admin_password

# Your Telegram user ID (for bot command authorization)
# Send /start to @userinfobot to get it
ADMIN_TELEGRAM_ID=0

# ─── Security ──────────────────────────────────────────
# Token lifetime in seconds (default: 4 hours)
TOKEN_LIFETIME=14400

# CORS — your website domain(s), comma-separated
# Use * for development, restrict in production
ALLOWED_ORIGINS=*

# ─── Performance ───────────────────────────────────────
# MTProto chunk size — max 1MB (Telegram protocol limit)
CHUNK_SIZE=1048576

# Max concurrent streams per IP
MAX_STREAMS_PER_IP=5
